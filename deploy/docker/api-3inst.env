# ============================================================
# M3 API 3 实例编排（替代单实例）
# 用法：docker compose -f docker-compose.3inst.yml up -d
# 配合 nginx upstream 3 个端口（3001/3002/3003）做 round-robin 负载均衡
# ============================================================
name: wm-card-prod-3inst

services:
  api-1:
    image: wm-card-prod-api:latest
    container_name: wm-card-api-1
    restart: always
    network_mode: host
    env_file: /opt/wm-card/.env.prod
    environment:
      NODE_ENV: production
      PORT: 3001
    healthcheck:
      test: ['CMD', 'wget', '--quiet', '--tries=1', '--spider', 'http://localhost:3001/api/health']
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 30s

  api-2:
    image: wm-card-prod-api:latest
    container_name: wm-card-api-2
    restart: always
    network_mode: host
    env_file: /opt/wm-card/.env.prod
    environment:
      NODE_ENV: production
      PORT: 3002
    healthcheck:
      test: ['CMD', 'wget', '--quiet', '--tries=1', '--spider', 'http://localhost:3002/api/health']
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 30s

  api-3:
    image: wm-card-prod-api:latest
    container_name: wm-card-api-3
    restart: always
    network_mode: host
    env_file: /opt/wm-card/.env.prod
    environment:
      NODE_ENV: production
      PORT: 3003
    healthcheck:
      test: ['CMD', 'wget', '--quiet', '--tries=1', '--spider', 'http://localhost:3003/api/health']
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 30s