# ============== 数据库 ==============
DATABASE_URL="mysql://wm:wm_pwd@127.0.0.1:3306/wm_card"

# ============== Redis ==============
REDIS_URL="redis://127.0.0.1:6379/0"

# ============== JWT ==============
# access token 密钥（至少 32 字符）
JWT_SECRET="change-me-to-a-random-32+char-string"
JWT_EXPIRES_IN="15m"
# refresh token 密钥（与 JWT_SECRET 不同）
JWT_REFRESH_SECRET="change-me-to-another-random-32+char-string"
JWT_REFRESH_EXPIRES_IN="7d"

# ============== 卡密加密 ==============
# AES-256-GCM 密钥，必须 32 字节
# 生成方式：openssl rand -hex 32  （输出 64 位 hex 字符串）
# 或：openssl rand -base64 32      （输出 44 位 base64 字符串）
# 生产环境务必妥善保管，丢失即所有卡密不可解密
STOCK_ENCRYPTION_KEY=""

# ============== 管理员初始账号（仅 seed 使用）==============
ADMIN_USERNAME="admin"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me-on-first-login"

# ============== 服务 ==============
PORT=3000
NODE_ENV="development"
CORS_ORIGIN="http://localhost:5173"
