// ============================================================
// WM 官方虚拟卡密交易平台 - Prisma Schema
// ============================================================
// 生成客户端：npx prisma generate
// 迁移：npx prisma migrate dev --name init
// ============================================================

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================================
// 用户与权限
// ============================================================

enum UserRole {
  SUPER_ADMIN
  MERCHANT
  STAFF
}

model User {
  id           String         @id @default(uuid())
  username     String         @unique @db.VarChar(64)
  email        String         @unique @db.VarChar(255)
  passwordHash String         @db.VarChar(255)
  role         UserRole       @default(STAFF)
  merchantId   String?
  merchant     Merchant?      @relation(fields: [merchantId], references: [id])
  isActive     Boolean        @default(true)
  // token 版本号：改密/角色变更时 +1，使旧 refresh token 失效（防盗号后改密仍可刷新）
  tokenEpoch   Int            @default(0)
  lastLoginAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deletedAt    DateTime?

  auditLogs    AuditLog[]

  @@index([role])
  @@index([merchantId])
  @@map("users")
}

// ============================================================
// 商户与店铺
// ============================================================

model Merchant {
  id           String   @id @default(uuid())
  code         String   @unique @db.VarChar(32)
  name         String   @db.VarChar(128)
  contactEmail String  @db.VarChar(255)
  status       MerchantStatus @default(PENDING)
  commissionRate Decimal @db.Decimal(5,4) @default(0)
  // 可提现余额
  balance      Decimal @db.Decimal(12,2) @default(0)
  // 冻结余额（投诉/工单占用、未来兼容 T+1 自动提现）
  freezeBalance Decimal @db.Decimal(12,2) @default(0)
  // 累计提现金额（统计用）
  totalWithdrawn Decimal @db.Decimal(12,2) @default(0)
  // 商户工作台主题色（hex，如 #7c3aed）
  themeColor   String?  @db.VarChar(9)
  // 冻结状态（投诉过多自动冻结）
  frozenReason String?  @db.Text
  frozenAt     DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  users        User[]
  shops        Shop[]
  products     Product[]
  apiKeys      ApiKey[]
  withdrawals  Withdrawal[]
  paymentChannels MerchantPaymentChannel[]
  inviteCodes  InviteCode[]
  commissionsAsInviter CommissionRecord[] @relation("CommissionInviter")
  commissionsAsSource  CommissionRecord[] @relation("CommissionSource")
  receivedNotifications Notification[] @relation("NotificationRecipientMerchant")

  @@map("merchants")
}

enum MerchantStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REJECTED
}

model ApiKey {
  id          String    @id @default(uuid())
  key         String    @unique @db.VarChar(64) // sk_live_xxx（3 天过渡后删除）
  keyHash     String?   @unique @db.VarChar(64) // sha256(key) hex，新主存储
  keyHint     String    @db.VarChar(16)         // sk_live_...xxxx（列表显示用）
  name        String    @db.VarChar(64)         // 描述性名称
  merchantId  String
  merchant    Merchant  @relation(fields: [merchantId], references: [id])
  scopes      String    @db.VarChar(255) @default("read,write") // read / write
  rateLimitPerMin Int   @default(60)             // 每分钟请求上限
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  revokedAt   DateTime?

  @@index([merchantId])
  @@map("api_keys")
}

model Shop {
  id          String   @id @default(uuid())
  merchantId  String
  merchant    Merchant @relation(fields: [merchantId], references: [id])
  code        String   @unique @db.VarChar(32) // 路径式访问 /shop/:code
  name        String   @db.VarChar(128)
  announcement String?  @db.Text
  footerHtml  String?  @db.Text
  isOnline    Boolean  @default(true)
  customDomain      String?  @unique @db.VarChar(255)  // 商户自定义域名（如 shop.example.com）
  domainVerified    Boolean  @default(false)             // DNS TXT 是否已验证
  domainVerifyToken String?  @db.VarChar(64)            // TXT 记录验证令牌
  domainVerifiedAt  DateTime?                            // 验证通过时间
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products    Product[]
  orders      Order[]
  pageViews   PageView[]
  tickets     Ticket[]

  @@index([merchantId])
  @@index([customDomain])
  @@map("shops")
}

// ============================================================
// 商品与卡密
// ============================================================

model ProductCategory {
  id          String   @id @default(uuid())
  shopId      String
  name        String   @db.VarChar(64)
  sort        Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products    Product[]

  @@index([shopId])
  @@map("product_categories")
}

model Product {
  id          String   @id @default(uuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id])
  merchantId  String
  merchant    Merchant @relation(fields: [merchantId], references: [id])
  categoryId  String?
  category    ProductCategory? @relation(fields: [categoryId], references: [id])
  name        String   @db.VarChar(255)
  description String?  @db.Text
  price       Decimal @db.Decimal(10,2)
  originalPrice Decimal? @db.Decimal(10,2)
  status      ProductStatus @default(OFFLINE)
  purchaseLimit Int?   // 单次限购数量
  isAutoDelivery Boolean @default(true)
  sort        Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  stockCards  StockCard[]
  orderItems  OrderItem[]

  @@index([shopId])
  @@index([merchantId])
  @@index([status])
  @@map("products")
}

enum ProductStatus {
  ONLINE
  OFFLINE
  SOLD_OUT
}

model StockCard {
  id              String   @id @default(uuid())
  productId       String
  product         Product @relation(fields: [productId], references: [id])
  contentCiphertext String @db.Text    // AES-256-GCM 密文（base64）
  contentIv       String   @db.VarChar(64)  // 初始化向量（base64）
  contentTag      String   @db.VarChar(64)  // 认证标签（base64）
  contentHash     String   @db.VarChar(64)  // 内容 SHA256（用于去重）
  status          StockCardStatus @default(AVAILABLE)
  orderId         String?  @unique            // 唯一索引：防同一订单重复取卡
  order           Order?   @relation(fields: [orderId], references: [id])
  importedAt      DateTime @default(now())
  soldAt          DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([productId, status])
  @@index([contentHash])
  @@map("stock_cards")
}

enum StockCardStatus {
  AVAILABLE
  LOCKED
  SOLD
  DISABLED
}

// ============================================================
// 订单
// ============================================================

model Order {
  id             String   @id @default(uuid())
  orderNo        String   @unique @db.VarChar(32)   // 雪花 ID，对外暴露
  shopId         String
  shop           Shop     @relation(fields: [shopId], references: [id])
  buyerEmail     String   @db.VarChar(255)
  buyerContact   String?  @db.VarChar(64)  // 手机号
  buyerIp        String   @db.VarChar(64)
  buyerUserAgent String?  @db.VarChar(512)
  totalAmount    Decimal @db.Decimal(12,2)
  status         OrderStatus @default(PENDING)
  expireAt       DateTime
  paidAt         DateTime?
  deliveredAt    DateTime?
  viewedAt       DateTime?  // 买家首次查看卡密时间，作为"确认收货"依据
  idempotencyKey String?  @unique @db.VarChar(64)
  // 邀请码（P2-1 返佣用，下单时绑定）
  usedInviteCode String?  @db.VarChar(16)
  remark         String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  items          OrderItem[]
  stockCards     StockCard[]
  payments       Payment[]
  tickets        Ticket[]

  @@index([shopId])
  @@index([status])
  @@index([buyerEmail])
  @@index([expireAt])
  @@index([usedInviteCode])
  @@map("orders")
}

enum OrderStatus {
  PENDING    // 待支付
  PAID       // 已支付
  DELIVERED  // 已发卡
  EXPIRED    // 已超时
  REFUNDED   // 已退款
  CLOSED     // 已关闭
}

model OrderItem {
  id          String   @id @default(uuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id])
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  productName String   @db.VarChar(255)  // 下单时快照
  unitPrice   Decimal @db.Decimal(10,2)
  quantity    Int
  subtotal   Decimal @db.Decimal(12,2)
  createdAt   DateTime @default(now())

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

// ============================================================
// 支付
// ============================================================

model Payment {
  id             String   @id @default(uuid())
  orderId        String
  order          Order    @relation(fields: [orderId], references: [id])
  channel        String   @db.VarChar(32)
  tradeNo        String?  @unique @db.VarChar(64)  // 通道流水号
  amount         Decimal @db.Decimal(12,2)
  status         PaymentStatus @default(PENDING)
  paidAt         DateTime?
  rawNotify      String?  @db.Text  // 原始回调数据（脱敏后）
  // USDT 加密货币支付字段
  usdtWallet     String?  @db.VarChar(64)   // 收款钱包地址（TRC20）
  usdtAmount     Decimal? @db.Decimal(18,6) // 应收 USDT 数量（含唯一后缀）
  usdtTxHash     String?  @db.VarChar(80)  // Tron 链上交易哈希
  expiresAt      DateTime?                  // 支付超时时间
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([orderId])
  @@index([channel, status])
  @@index([usdtWallet, status])
  @@map("payments")
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
  EXPIRED
}

model PaymentChannel {
  id          String   @id @default(uuid())
  code        String   @unique @db.VarChar(32)  // epay / wechat / alipay / usdt
  name        String   @db.VarChar(64)
  isAvailable Boolean  @default(true)
  config      String   @db.Text  // 加密存储配置（密钥等）
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("payment_channels")
}

// ============================================================
// 系统配置
// ============================================================

model SystemConfig {
  id    String   @id @default(uuid())
  key   String   @unique @db.VarChar(64)
  value String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("system_configs")
}

// ============================================================
// 审计日志（仅追加，禁止 update/delete）
// ============================================================

model AuditLog {
  id           String   @id @default(uuid())
  actorId      String?
  actor        User?    @relation(fields: [actorId], references: [id])
  actorName    String?  @db.VarChar(64)
  action       String   @db.VarChar(64)
  resourceType String   @db.VarChar(64)
  resourceId   String?  @db.VarChar(128)
  beforeData  String?  @db.Text
  afterData   String?  @db.Text
  ip           String?  @db.VarChar(64)
  userAgent    String?  @db.VarChar(512)
  requestId    String?  @db.VarChar(64)
  createdAt    DateTime @default(now())

  @@index([actorId])
  @@index([resourceType, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================================
// 风控：IP/邮箱黑名单 + 行为记录
// ============================================================

model IpBlacklist {
  id        String    @id @default(uuid())
  ip        String    @unique @db.VarChar(64)
  reason    String    @db.Text
  source    String    @default("manual") @db.VarChar(32) // manual / auto
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  @@index([ip])
  @@index([expiresAt])
  @@map("ip_blacklist")
}

model EmailBlacklist {
  id        String    @id @default(uuid())
  email     String    @unique @db.VarChar(255)
  reason    String    @db.Text
  source    String    @default("manual") @db.VarChar(32)
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
  @@index([expiresAt])
  @@map("email_blacklist")
}

model RiskRecord {
  id        String   @id @default(uuid())
  ip        String   @db.VarChar(64)
  email     String?  @db.VarChar(255)
  action    String   @db.VarChar(64) // order.create / order.pending / login.failed 等
  detail    String?  @db.Text
  createdAt DateTime @default(now())

  @@index([ip, createdAt])
  @@index([email, createdAt])
  @@index([action, createdAt])
  @@map("risk_records")
}

// ============================================================
// V2：商户入驻申请
// ============================================================

model EmailVerification {
  id        String   @id @default(uuid())
  email     String   @db.VarChar(255)
  code      String   @db.VarChar(8)   // 6 位数字
  type      String   @db.VarChar(32)  // merchant_apply 等
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([email, type])
  @@index([expiresAt])
  @@map("email_verifications")
}

model MerchantApplication {
  id              String   @id @default(uuid())
  contactName     String?  @db.VarChar(64)
  contactEmail    String   @db.VarChar(255)
  contactPhone    String?  @db.VarChar(32)
  merchantName    String   @db.VarChar(128) // 申请的商户名称
  shopName        String   @db.VarChar(128) // 申请的店铺名称
  shopCode        String   @db.VarChar(32) // 店铺路径码，如 /shop/myshop
  businessScope   String?  @db.Text // 经营范围说明
  status          ApplicationStatus @default(PENDING)
  rejectReason    String?  @db.Text
  reviewedById    String?  @db.VarChar(64)
  reviewedAt      DateTime?
  approvedMerchantId String? @db.VarChar(36) // 审核通过后创建的 merchant.id
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([shopCode])
  @@index([status])
  @@index([contactEmail])
  @@map("merchant_applications")
}

enum ApplicationStatus {
  PENDING       // 待审核
  APPROVED      // 已通过
  REJECTED      // 已拒绝
}

// ============================================================
// 提现结算
// ============================================================

enum WithdrawalMethod {
  ALIPAY      // 支付宝
  WECHAT      // 微信
  BANK        // 银行卡
  USDT        // 加密货币
}

enum WithdrawalStatus {
  PENDING     // 待审核
  APPROVING   // 审核通过待打款
  PAID        // 已打款
  REJECTED    // 已拒绝
  FAILED      // 打款失败
}

model Withdrawal {
  id            String   @id @default(uuid())
  merchantId    String
  merchant      Merchant @relation(fields: [merchantId], references: [id])
  amount        Decimal  @db.Decimal(12,2)  // 申请金额
  fee           Decimal  @db.Decimal(12,2)  @default(0)  // 手续费
  actual        Decimal  @db.Decimal(12,2)  // 实际到账 (amount - fee)
  method        WithdrawalMethod
  // 收款账户信息（JSON: { account, name, bankName? 等）
  accountInfo   String   @db.Text
  status        WithdrawalStatus @default(PENDING)
  rejectReason  String?  @db.Text
  transferRef   String?  @db.VarChar(128)  // 打款流水号/交易号
  processedById String?  @db.VarChar(36)    // 审核人
  processedAt   DateTime?
  requestedAt   DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([merchantId])
  @@index([status])
  @@index([requestedAt])
  @@map("withdrawals")
}

// ============================================================
// P0-3 生意罗盘：页面访问记录（UV/转化率）
// ============================================================

model PageView {
  id          String   @id @default(uuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  path        String   @db.VarChar(255)
  ip          String   @db.VarChar(64)
  userAgent   String?  @db.VarChar(512)
  // visitorId = sha256(ip + ua + salt) 前 16 字符，用于去重而不存原始 IP
  visitorId   String   @db.VarChar(64)
  createdAt   DateTime @default(now())

  @@index([shopId, createdAt])
  @@index([visitorId, shopId])
  @@map("page_views")
}

// ============================================================
// P1-1 平台公告 / 文章
// ============================================================

enum ArticleType {
  ANNOUNCEMENT   // 平台公告
  AGREEMENT      // 用户协议
  DISCLAIMER     // 免责声明
  ALLOWED_GOODS  // 可销售商品说明
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Article {
  id          String        @id @default(uuid())
  type        ArticleType
  title       String        @db.VarChar(255)
  content     String        @db.LongText
  slug        String?       @unique @db.VarChar(64)
  summary     String?       @db.VarChar(500)
  status      ArticleStatus @default(DRAFT)
  sort        Int           @default(0)
  publishedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([type, status, publishedAt])
  @@map("articles")
}

// ============================================================
// P1-2 商户选支付通道
// ============================================================

model MerchantPaymentChannel {
  id           String   @id @default(uuid())
  merchantId   String
  merchant     Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  channelCode  String   @db.VarChar(32)  // epay/mock/usdt
  isEnabled    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([merchantId, channelCode])
  @@index([merchantId])
  @@map("merchant_payment_channels")
}

// ============================================================
// P2-1 单层邀请码 + 返佣
// ============================================================

model InviteCode {
  id                String   @id @default(uuid())
  code              String   @unique @db.VarChar(16)
  inviterMerchantId String
  inviter           Merchant @relation(fields: [inviterMerchantId], references: [id], onDelete: Cascade)
  note              String?  @db.VarChar(255)
  // 统计：被使用次数
  usedCount         Int      @default(0)
  createdAt         DateTime @default(now())

  @@index([inviterMerchantId])
  @@map("invite_codes")
}

enum CommissionStatus {
  SETTLED   // 已结算
  REVERSED  // 已冲正（订单退款）
}

model CommissionRecord {
  id                String   @id @default(uuid())
  inviterMerchantId String
  inviter           Merchant @relation("CommissionInviter", fields: [inviterMerchantId], references: [id])
  sourceMerchantId  String
  source            Merchant @relation("CommissionSource", fields: [sourceMerchantId], references: [id])
  orderId           String?  @db.VarChar(36)
  orderNo           String?  @db.VarChar(32)
  // 返佣基数（商户利润 = 售价 - 成本，MVP 用订单金额 * 平台抽成率 简化）
  baseAmount        Decimal  @db.Decimal(12,2)
  // 返佣比例（平台全局配置）
  rate              Decimal  @db.Decimal(5,4)
  // 返佣金额 = baseAmount * rate
  amount            Decimal  @db.Decimal(12,2)
  status            CommissionStatus @default(SETTLED)
  createdAt         DateTime @default(now())

  @@index([inviterMerchantId, createdAt])
  @@index([sourceMerchantId])
  @@index([orderId])
  @@map("commission_records")
}

// ============================================================
// P2-2 投诉/工单
// ============================================================

enum TicketStatus {
  OPEN              // 待响应
  BUYER_REPLIED     // 买家已回
  MERCHANT_REPLIED  // 商户已回
  PLATFORM_REPLIED  // 平台已回
  RESOLVED          // 已解决
  AUTO_REFUNDED     // 24h 自动退款
  CLOSED            // 已关闭
}

enum TicketCategory {
  REFUND          // 退款
  DELIVERY        // 发卡问题
  QUALITY         // 商品质量
  OTHER           // 其他
}

model Ticket {
  id           String       @id @default(uuid())
  ticketNo     String       @unique @db.VarChar(32)
  orderId      String?      @db.VarChar(36)
  order        Order?       @relation(fields: [orderId], references: [id])
  shopId       String
  shop         Shop         @relation(fields: [shopId], references: [id])
  buyerEmail   String       @db.VarChar(255)
  buyerIp      String?      @db.VarChar(64)
  category     TicketCategory @default(OTHER)
  subject      String       @db.VarChar(255)
  description  String       @db.Text
  status       TicketStatus @default(OPEN)
  priority     Int          @default(0)
  lastRepliedAt DateTime?
  lastRepliedByRole String? @db.VarChar(32)  // buyer/merchant/platform
  // 24h 自动退款时间点（创建时 + 24h）
  autoRefundAt DateTime?
  resolvedAt   DateTime?
  // 退款金额（AUTO_REFUNDED 时记录）
  refundAmount Decimal?     @db.Decimal(12,2)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  messages     TicketMessage[]

  @@index([shopId, status])
  @@index([status, autoRefundAt])
  @@index([buyerEmail])
  @@map("tickets")
}

model TicketMessage {
  id          String   @id @default(uuid())
  ticketId    String
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderRole  String   @db.VarChar(32)  // buyer/merchant/platform
  senderId    String?  @db.VarChar(64)
  senderName  String?  @db.VarChar(64)
  content     String   @db.Text
  isInternal  Boolean  @default(false)  // 平台内部备注，买家/商户不可见
  createdAt   DateTime @default(now())

  @@index([ticketId, createdAt])
  @@map("ticket_messages")
}

// ============================================================
// P2-3 站内信
// ============================================================

enum NotificationType {
  ORDER        // 订单
  WITHDRAWAL   // 提现
  TICKET       // 工单
  SYSTEM       // 系统
  COMMISSION   // 返佣
}

model Notification {
  id                    String           @id @default(uuid())
  recipientMerchantId   String?
  recipient             Merchant?        @relation("NotificationRecipientMerchant", fields: [recipientMerchantId], references: [id], onDelete: Cascade)
  recipientUserId       String?          @db.VarChar(64)  // 平台管理员等
  type                  NotificationType @default(SYSTEM)
  title                 String           @db.VarChar(255)
  content               String           @db.Text
  link                  String?          @db.VarChar(255)
  isRead                Boolean          @default(false)
  readAt                DateTime?
  emailSent             Boolean          @default(false)
  createdAt             DateTime         @default(now())

  @@index([recipientMerchantId, isRead, createdAt])
  @@index([recipientUserId, isRead, createdAt])
  @@map("notifications")
}
