# ============================================================
# WM 官方虚拟卡密交易平台 - 环境变量模板
# ============================================================
# 复制本文件为 .env 并填入真实值。
# .env 绝不入库，所有密钥必须从环境变量读取。
# 详见 SECURITY-BASELINE.md §12。
# ============================================================

# ---- 运行环境 ----
NODE_ENV=development
PORT=3000
API_PREFIX=api
FRONTEND_URL=http://localhost:5173
# 信任的反代地址（Express trust proxy），loopback/单 IP/CIDR/逗号分隔多 IP
# 生产环境填 Nginx 所在服务器 IP，如 127.0.0.1,162.251.93.5
TRUST_PROXY=loopback
# 平台主域名（商户自定义域名检测时排除），逗号分隔
MAIN_DOMAINS=winmelon.cn,www.winmelon.cn,localhost

# ---- 数据库 (MySQL 8) ----
DATABASE_URL=mysql://wmcard:CHANGE_ME_STRONG_PASSWORD@localhost:3306/wmcard
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD
MYSQL_DATABASE=wmcard
MYSQL_USER=wmcard
MYSQL_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ---- Redis 7 ----
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@localhost:6379/0
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ---- 安全密钥（生成命令见下方说明）----
# JWT_SECRET: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_64_BYTES_RANDOM_HEX
# JWT_REFRESH_SECRET: openssl rand -hex 64（与 JWT_SECRET 不同）
JWT_REFRESH_SECRET=CHANGE_ME_64_BYTES_RANDOM_HEX_DIFFERENT
# SESSION_SECRET: openssl rand -hex 32
SESSION_SECRET=CHANGE_ME_32_BYTES_RANDOM_HEX
# CARD_ENCRYPTION_KEY: openssl rand -base64 32（用于 AES-256-GCM 加密卡密）
CARD_ENCRYPTION_KEY=CHANGE_ME_32_BYTES_BASE64

# ---- JWT 有效期 ----
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---- 限流策略 ----
RATE_LIMIT_GLOBAL_PER_MIN=60
RATE_LIMIT_ORDER_PER_MIN=10
RATE_LIMIT_QUERY_PER_MIN=30
RATE_LIMIT_LOGIN_PER_MIN=5

# ---- 订单超时（毫秒）默认 10 分钟 ----
ORDER_EXPIRE_MS=600000

# ---- 初始管理员（首次启动自动创建，创建后请立即修改密码）----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
ADMIN_EMAIL=admin@example.com

# ---- 支付通道（按需启用，MVP 先用易支付）----
# 易支付（彩虹）通道
EPAY_API_URL=
EPAY_PID=
EPAY_KEY=
EPAY_NOTIFY_URL=
EPAY_RETURN_URL=

# 微信支付官方（V2 启用，需商户号）
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_CERT_SERIAL_NO=
WECHAT_PAY_PRIVATE_KEY_PATH=

# 支付宝官方（V2 启用，需商户号）
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=

# ---- 通知通道（V3）----
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ---- 日志级别 ----
LOG_LEVEL=debug

# ---- 域名（上线后填写）----
DOMAIN=
